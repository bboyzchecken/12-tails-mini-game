ENV=development
PORT=5000

# Comma-separated CORS origins (game client + landing). Use * for quick local dev.
# Prod example: https://12tails.pages.dev,https://play.12tails.example
CLIENT_ORIGIN=*

# Reserved for player/admin auth (Phase P) — unused in Phase 1.
JWT_SECRET_KEY=change-me

# --- Postgres ---
# Either set DATABASE_URL (wins), or the discrete POSTGRES_* parts below.
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/twelvetails?sslmode=disable
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=twelvetails
POSTGRES_SSLMODE=disable
