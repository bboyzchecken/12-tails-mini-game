# 12Tails web (Next.js) — build-time public env. Copy to .env.local for dev.
# All NEXT_PUBLIC_* values are inlined into the client bundle (no secrets here).

# Go API base URL (no trailing slash). Landing analytics + waitlist + admin call
# this. In prod it's the AWS API domain.
NEXT_PUBLIC_API_URL=http://localhost:5055

# "Enter the community" → game client. Dev default is the local game (port 8080).
NEXT_PUBLIC_GAME_URL=http://localhost:8080

# Community invite shown on the landing (set before promoting publicly).
# NEXT_PUBLIC_DISCORD_URL=
