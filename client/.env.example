# คัดลอกเป็น .env.local แล้วแก้ค่า (Vite อ่านตอน dev/build)
# URL ของ game server (Socket.IO)
#   dev ในเครื่อง:      http://localhost:3001
#   ทดสอบมือถือใน LAN:  http://<IP-เครื่องเรา>:3001  (เช่น http://192.168.1.50:3001)
#   production:          https://<ชื่อ-app>.onrender.com  หรือ Railway URL
VITE_SERVER_URL=http://localhost:3001
