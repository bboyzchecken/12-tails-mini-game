# ══════════════════════════════════════════════════════════════════════════
#  12Tails — ONE .env for the whole stack, grouped by service.
#  Copy to .env:  cp .env.example .env
#  Port values are HOST ports; docker compose maps them to the container ports.
#  (The same file also works for local `go run` inside ./api.)
# ══════════════════════════════════════════════════════════════════════════

# ───────────── POSTGRES (used by API) ─────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=twelvetails
POSTGRES_HOST=localhost          # local `go run` uses this; in compose the API uses host "postgres"
POSTGRES_PORT=5433               # HOST port (mapped to container 5432)
POSTGRES_SSLMODE=disable

# ───────────── API (Go · /api) ─────────────
ENV=development
API_PORT=5055                    # HOST port (mapped to container 5000)
JWT_SECRET_KEY=dev-secret-change-me
CLIENT_ORIGIN=http://localhost:8080,http://localhost:5173   # who may call the API (CORS)
# Admin dashboard seed (Phase 4): when both are set, an admin account is created
# on startup if missing. There is no public admin register.
ADMIN_EMAIL=admin@12tails.local
ADMIN_PASSWORD=change-me-admin
ADMIN_FAMILY_NAME=Admin

# ───────────── SERVER (Socket.IO relay · /server) ─────────────
SERVER_PORT=3001
SERVER_CLIENT_ORIGIN=http://localhost:8080,http://localhost:5173

# ───────────── CLIENT (game · /client · Vite build-time) ─────────────
CLIENT_PORT=8080                 # HOST port (nginx serves on 80)
VITE_SERVER_URL=http://localhost:3001
VITE_API_URL=http://localhost:5055

# ───────────── WEB (Next.js · /web) — later phase, not built yet ─────────────
# WEB_PORT=3000
# NEXT_PUBLIC_API_URL=http://localhost:5055
